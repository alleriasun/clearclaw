{
  "name": "clearclaw",
  "version": "0.2.0",
  "description": "Your coding agent, from your phone — personal assistant + project workspaces on your machine, built on the CLI's permissions, config, and memory instead of replacing them.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alleriasun/clearclaw.git"
  },
  "homepage": "https://github.com/alleriasun/clearclaw",
  "keywords": [
    "claude-code",
    "telegram",
    "relay",
    "agent-sdk",
    "cli",
    "remote",
    "mobile",
    "openclaw",
    "nanoclaw",
    "remotecode"
  ],
  "bin": {
    "clearclaw": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "dev:relay": "nodemon --watch dist --exec 'node dist/index.js'",
    "build": "tsc",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.50",
    "diff": "^8.0.3",
    "grammy": "^1.30.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "^22.0.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
